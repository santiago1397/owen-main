# Copy to .env.prod on the server, fill in real values, chmod 600. Never commit.

# Traefik Host() rule uses this: api.${APP_DOMAIN} for the backend.
APP_DOMAIN=example.com

ENVIRONMENT=production
DEBUG=false

# Frontend origin allowed to call the API (frontend lives on app.<APP_DOMAIN>).
CORS_ORIGINS=https://app.example.com

# Native host Postgres (see SERVER_SETUP.md PostgreSQL strategy, Option A).
# Create: sudo -u postgres createuser callmon; createdb -O callmon callmon
# And add the callmon-net bridge subnet to pg_hba.conf (NOT just 172.17/16).
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_USER=callmon
POSTGRES_PASSWORD=CHANGE_ME_STRONG
POSTGRES_DB=callmon

# Auth — generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

BUSINESS_TZ=America/New_York

# Twilio: auth token verifies X-Twilio-Signature; account SID enables reconciliation pulls.
# Primary account. Also the fallback single account when TWILIO_ACCOUNTS is unset.
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME

# Multiple Twilio accounts (optional). JSON list; each account becomes its own provider
# identity (its own Provider row / provider name). When set, this is the FULL list —
# include the primary account explicitly. When empty, the single account above is used.
# Example:
# TWILIO_ACCOUNTS=[{"name":"twilio","sid":"ACxxx","token":"tok1"},{"name":"twilio-b","sid":"ACyyy","token":"tok2"}]
TWILIO_ACCOUNTS=

# SignalWire (Compatibility API). Leave blank until Phase 3 provider is wired.
SIGNALWIRE_PROJECT_ID=
SIGNALWIRE_AUTH_TOKEN=
SIGNALWIRE_SPACE_URL=
# Shared secret for Call Flow Builder's "Request" node (HTTP Basic Auth, since it can't
# produce a signed webhook). Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
SIGNALWIRE_CFB_WEBHOOK_SECRET=

RECONCILE_WINDOW_HOURS=4

# --- Asterisk / BulkVS telephony (additive, DARK + flag-gated) ----------------------
# Native-Asterisk + BulkVS SIP trunk as a 3rd provider. Ships OFF: with ASTERISK_ENABLED
# false nothing about the app changes (no telephony consumers, Twilio/SignalWire/GHL
# untouched). Flip true only after provisioning the host per asterisk/README.md.
# /health/telephony is the non-gating probe (NOT the container healthcheck).
ASTERISK_ENABLED=false
# ARI (Asterisk REST Interface) — the backend reaches it over the docker host-gateway;
# it is bound + UFW-locked to loopback/callmon-net, never public. Creds from env only.
ARI_HOST=host.docker.internal
ARI_PORT=8088
ARI_USERNAME=owen
ARI_PASSWORD=            # generate: openssl rand -hex 24
ARI_APP=owen             # Stasis application name
# Deploy-render only (used by envsubst on asterisk/http.conf, NOT read by the backend):
# the callmon-net gateway IP Asterisk binds ARI to, e.g. 172.20.0.1.
ARI_BIND_ADDR=127.0.0.1
# BulkVS SIP trunk. Inbound is IP-authed by the SBCs (see asterisk/README.md); the
# username/password cover outbound auth/registration. Secrets stay here, never in git.
BULKVS_TRUNK_NAME=bulkvs
BULKVS_SIP_USERNAME=
BULKVS_SIP_PASSWORD=
BULKVS_FROM_NUMBER=      # default outbound caller-ID, E.164 e.g. +1XXXXXXXXXX

# Transcription engine: dummy | openai. MUST be set to "openai" for real transcripts —
# "dummy" (the code default) silently returns a canned fake sentence for every call.
TRANSCRIPTION_ENGINE=openai
OPENAI_API_KEY=
# gpt-4o-transcribe (not whisper-1): same price ($0.006/min), far less prone to
# hallucinating fake text on short/near-silent audio. Does NOT support
# response_format=verbose_json (json/text only) — fine, that's what we send.
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe

# Dual-channel ("who said what") transcription. SignalWire's Start Call Recording node
# records in stereo — each call leg on its own channel — so the transcribe worker splits
# a 2-channel recording (ffmpeg) into two mono tracks, transcribes each, and merges them
# into a speaker-labeled transcript. Mono recordings (Twilio / pre-stereo) are unaffected.
STEREO_TRANSCRIPTION_ENABLED=true
# Which channel index (0/1) is the inbound caller. CONFIRM on a real stereo test call
# before trusting labels — flip this if Caller/Operator come out swapped.
STEREO_CALLER_CHANNEL=0
# Segment timestamps (to interleave the two legs) need whisper-1 — gpt-4o-transcribe can't
# return them. whisper-1 hallucinates on the silent stretches of a split channel, so its
# segments are filtered by these thresholds.
OPENAI_STEREO_TRANSCRIBE_MODEL=whisper-1
STEREO_MAX_NO_SPEECH_PROB=0.6
STEREO_MIN_AVG_LOGPROB=-1.2

# Analysis engine: dummy | claude | minimax
ANALYSIS_ENGINE=dummy
ANALYSIS_MODEL=MiniMax-M2
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1

RECORDINGS_DIR=/data/recordings
RECORDING_RETENTION_DAYS=30

# GoHighLevel inbound-SMS relay. Paste the URL of a GHL Workflow "Inbound Webhook"
# trigger; inbound texts received on tracking numbers are POSTed here as JSON.
# Leave blank to disable relay (messages are still stored in OWEN). Inbound-only —
# OWEN never sends outbound SMS, so this incurs no messaging charge.
GHL_INBOUND_WEBHOOK_URL=

# GoHighLevel parsed-email relay — two options, direct API preferred.
#
# Option A (preferred): direct v2 API. A parsed job email upserts a Contact and creates an
# Opportunity in a pipeline. No GHL premium per-execution charge; we handle retries/dedup.
# Create a sub-account Private Integration Token (Settings > Private Integrations) with
# contacts + opportunities read/write scopes. Pipeline/stage IDs are resolved via a one-off
# lookup and pasted here (leave stage blank to use the pipeline's first stage).
GHL_API_TOKEN=
GHL_LOCATION_ID=
GHL_PIPELINE_ID=
GHL_PIPELINE_STAGE_ID=
#
# Option B (fallback): GHL "Inbound Webhook" trigger URL (premium; ~$0.01/execution).
# Used only when GHL_API_TOKEN is empty. Blank = relay disabled (emails still stored).
GHL_EMAIL_WEBHOOK_URL=

# Inbound email ingestion (Hostinger IMAP). The worker polls this mailbox for job-
# notification emails (Dispatch / American Home Shield), parses them, and relays parsed
# ones to GHL_EMAIL_WEBHOOK_URL. Leave INBOUND_MAIL_HOST blank to disable the poller.
# Hostinger has no OAuth/app-passwords — use the real mailbox password over TLS (993).
# A dedicated mailbox is recommended. Only mail from INBOUND_MAIL_SENDER is ever touched.
INBOUND_MAIL_HOST=imap.hostinger.com
INBOUND_MAIL_PORT=993
INBOUND_MAIL_USER=santiago@dreamteammetalroofingandsolar.com
INBOUND_MAIL_PASSWORD=
INBOUND_MAIL_FOLDER=INBOX
INBOUND_MAIL_SENDER=notifications@dispatch.me
INBOUND_MAIL_POLL_SECONDS=90
INBOUND_MAIL_BATCH=25
INBOUND_MAIL_MARK_SEEN=true
