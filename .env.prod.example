# Copy to .env.prod on the server, fill in real values, chmod 600. Never commit.

# Traefik Host() rule uses this: api.${APP_DOMAIN} for the backend.
APP_DOMAIN=example.com

ENVIRONMENT=production
DEBUG=false

# Frontend origin allowed to call the API (frontend lives on app.<APP_DOMAIN>).
CORS_ORIGINS=https://app.example.com

# Native host Postgres (see SERVER_SETUP.md PostgreSQL strategy, Option A).
# Create: sudo -u postgres createuser callmon; createdb -O callmon callmon
# And add the callmon-net bridge subnet to pg_hba.conf (NOT just 172.17/16).
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_USER=callmon
POSTGRES_PASSWORD=CHANGE_ME_STRONG
POSTGRES_DB=callmon

# Auth — generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

BUSINESS_TZ=America/New_York

# Twilio: auth token verifies X-Twilio-Signature; account SID enables reconciliation pulls.
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME

# SignalWire (Compatibility API). Leave blank until Phase 3 provider is wired.
SIGNALWIRE_PROJECT_ID=
SIGNALWIRE_AUTH_TOKEN=
SIGNALWIRE_SPACE_URL=

RECONCILE_WINDOW_HOURS=4

# Analysis engine: dummy | claude | minimax
ANALYSIS_ENGINE=dummy
ANALYSIS_MODEL=MiniMax-M2
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1

RECORDINGS_DIR=/data/recordings
RECORDING_RETENTION_DAYS=30
